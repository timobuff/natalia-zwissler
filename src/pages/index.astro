let hero = { titel: "Wasser · Erde · Feuer · Hände", untertitel: "Handgefertigte Unikate aus Leidenschaft", ctaText: "Kollektion entdecken" };
let intro = { titel: "Willkommen im Atelier", text: "Ton ist für mich mehr als nur Material. Es ist der Dialog zwischen der Rauheit der Erde und der Sanftheit der Formgebung. In meiner Werkstatt in Weinfelden entstehen Stücke, die Zeitlosigkeit und haptische Präsenz vereinen – gebrannt, um den Alltag zu bereichern." };

try { hero = await import('../content/einstellungen/hero.json'); } catch(e) {}
