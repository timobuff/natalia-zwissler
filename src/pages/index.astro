---
<BaseLayout title="Natalia Zwissler Keramik">
  <Nav />

  <Hero
    titel={hero.titel}
    untertitel={hero.untertitel}
    ctaText={hero.ctaText}
    bild="https://lh3.googleusercontent.com/aida-public/AB6AXuB29x2jqORguNAUKW_k5yWv0dBzJv9okIhd8w6n26dkOL9H7qoTk_lYLoGZSD6C_SrIh62HMsoZ7ZHBUHFCULR3-IU9TZl92Ch6eH7dANCqesl31iMXZKMMUFjKFj5b6LyYnLrLmWLRS-EcFIUwywBgpgmyQL2WTt7kGPUPAOQR52SH6RrRYyRVHKP4ywxHsCnjRE663G8KZ0BtxeSCQffdXapgYkrnaew1WtxGzF_WGJRJcCDxyKxU8z-ZWMFDyPHChYlmCmzujhQ"
    ctaLink="#gallery"
  />

  <section class="py-[100px] px-8 bg-surface">
    <div class="max-w-[640px] mx-auto text-center">
      <h2 class="font-headline text-4xl text-on-surface mb-8">{intro.titel}</h2>
      <p class="font-body text-lg leading-relaxed text-on-surface-variant">{intro.text}</p>
    </div>
  </section>

  <KategorienGrid kategorien={kategorien} />

  <section class="py-24 bg-[#EDE8E0] px-8 md:px-16 overflow-hidden">
    <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="w-full md:w-1/2">
        <span class="font-body uppercase tracking-[0.1em] text-primary text-sm font-bold block mb-4">Das Atelier</span>
        <h2 class="font-headline text-4xl lg:text-5xl mb-8 leading-tight">Ein Ort für Ton & Kreativität in Weinfelden.</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary mt-1">location_on</span>
            <p class="font-body text-on-surface-variant leading-relaxed">Musterweg 12<br/>8570 Weinfelden, Schweiz</p>
          </div>
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary mt-1">schedule</span>
            <p class="font-body text-on-surface-variant leading-relaxed">Freitag: 14:00 – 18:00 Uhr<br/>Samstag: 10:00 – 16:00 Uhr<br/>Und nach Vereinbarung.</p>
          </div>
        </div>
      </div>
      <div class="w-full md:w-1/2 relative">
        <div class="aspect-square bg-surface-container-highest relative z-10 p-4 border border-outline-variant/20">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAadddWB9baeUTMUBuLiWDYCPRgxijzOsuF-xbN0tyYrtuJkGCtB2W2Snj0KsLSFCwGAUPu_eCcnWo8mjNj_9bPqTKZBzfTI4cqPwv8FxiYq4gmhcMh5XeWzSrHEMpOyYAst1yNyqCFKSw-bSEOB0CyxnFqeOW_zDA3ve1E6NwM7hN3fubD_qHFABhJBfbvjm1OQzgNbqL8TcNKy7rcjvMoSHO9JNMhgWWGWblwQ46JKKVxNNSUckj0wYPhWz8SUeOrz4eHqDkupf4" alt="Atelier" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-[100px] px-8 md:px-16 bg-surface">
    <div class="max-w-screen-2xl mx-auto flex flex-col lg:flex-row gap-20">
      <div class="lg:w-1/2 order-2 lg:order-1">
        <div class="aspect-[16/9] bg-surface-container-highest relative overflow-hidden editorial-shadow">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuD7HJXLfLTZ3-xsQ6Epexhqdf9951ZBlhQwCI2sXOPCqkUmC2GTxUmhPoLCcgcIW7RpGa8ur7OuPNtnoJ9AKetozDzpwC-QjXkdzhylQGcxpBe5mb9jMtc8Fp6vzm2kkxMEMXF6uwv7eymWXaob9e7-LKLjZFBB3CxppocOkcjweDRk5MtwTsvQKFg1OqEp8w4aATJXVMMPVrUdMHAEOsjdsVrMQNcWGKdCVPGufs2jLy7pIH8MSF46VwMigkWdpApdATrpUbCqI8" alt="Töpferkurs" class="w-full h-full object-cover" />
        </div>
      </div>
      <div class="lg:w-1/2 order-1 lg:order-2 flex flex-col justify-center">
        <span class="font-body uppercase tracking-[0.1em] text-primary text-sm font-bold block mb-4">Bildung</span>
        <h2 class="font-headline text-4xl lg:text-5xl mb-8 leading-tight">Töpferkurse: Das Handwerk selbst erleben.</h2>
        <p class="font-body text-lg text-on-surface-variant leading-relaxed mb-10">In meinen Kursen vermittle ich die Grundlagen und Fortgeschrittenentechniken der Keramik. Ob an der Drehscheibe oder in der Aufbautechnik – entdecken Sie die meditativen Eigenschaften des Materials.</p>
        <div class="flex flex-wrap gap-6">
          <a href="#" class="bg-primary text-white px-10 py-4 font-body uppercase tracking-widest text-sm hover:bg-primary-container transition-all">Aktuelle Kurse</a>
          <a href="#" class="border border-outline px-10 py-4 font-body uppercase tracking-widest text-sm hover:border-primary transition-all">Gutschein kaufen</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
